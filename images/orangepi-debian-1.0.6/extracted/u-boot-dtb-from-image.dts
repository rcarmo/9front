	soc@29000000 {
		compatible = "simple-bus";
		#address-cells = <0x02>;
		#size-cells = <0x02>;

		power_sply@4500000c {
			device_type = "power_sply";
			ntc_status = <0x02>;
			battery_exist = <0x00>;
		};

		power_delay@4500024 {
			device_type = "power_delay";
		};

		platform@45000004 {
			device_type = "platform";
			eraseflag = <0x01>;
			next_work = <0x03>;
			debug_mode = <0x04>;
		};

		target@45000008 {
			device_type = "target";
			boot_clock = <0x3f0>;
			storage_type = <0xffffffff>;
			burn_key = <0x01>;
			dragonboard_test = <0x00>;
		};

		charger0@45000010 {
			device_type = "charger0";
			pmu_safe_vol = <0xd48>;
			bat_bmp_type = <0x01>;
			ntc_cur = <0x3c>;
			safe_temp_H = <0x258>;
			safe_temp_L = <0xffffffce>;
			pmu_bat_temp_para1 = <0x11bd>;
			pmu_bat_temp_para2 = <0xaca>;
			pmu_bat_temp_para3 = <0x884>;
			pmu_bat_temp_para4 = <0x6c4>;
			pmu_bat_temp_para5 = <0x56a>;
			pmu_bat_temp_para6 = <0x45d>;
			pmu_bat_temp_para7 = <0x389>;
			pmu_bat_temp_para8 = <0x25e>;
			pmu_bat_temp_para9 = <0x19e>;
			pmu_bat_temp_para10 = <0x122>;
			pmu_bat_temp_para11 = <0xf4>;
			pmu_bat_temp_para12 = <0xcd>;
			pmu_bat_temp_para13 = <0xb0>;
			pmu_bat_temp_para14 = <0x96>;
			pmu_bat_temp_para15 = <0x6f>;
			pmu_bat_temp_para16 = <0x53>;
		};

		card_boot@45000014 {
			device_type = "card_boot";
			logical_start = <0xa000>;
			boot_work_delay = <0x82>;
			boot_work_times = <0x03>;
			sprite_gpio0 = <0x14 0x08 0x09 0x01 0xffffffff 0xffffffff 0x00>;
		};

		gpio_bias@45000018 {
			device_type = "gpio_bias";
		};

		fastboot_key@4500001c {
			device_type = "fastboot_key";
			key_max = <0x2a>;
			key_min = <0x26>;
		};

		recovery_key@45000020 {
			device_type = "recovery_key";
			key_max = <0x1f>;
			key_min = <0x1c>;
		};

		adc_boot_recovery@45000024 {
			device_type = "adc_boot_recovery";
			recovery_adc_used = <0x01>;
			recovery_adc_channel = <0x00>;
			press_mode_enable = <0x01>;
			short_press_mode = <0x00>;
			long_press_mode = <0x02>;
			key_press_time = <0x7d0>;
			key_min = <0x09>;
			key_max = <0x0b>;
		};

		gpadc_boot_recovery@45000024 {
			device_type = "gpadc_boot_recovery";
			recovery_adc_used = <0x01>;
			recovery_adc_channel = <0x09>;
			press_mode_enable = <0x01>;
			short_press_mode = <0x00>;
			long_press_mode = <0x03>;
			key_press_time = <0x1388>;
			key_min = <0x1c7>;
			key_max = <0x1f4>;
		};

		key_boot_recovery@45000028 {
			device_type = "key_boot_recovery";
		};

		pinctrl@0300b000 {
			compatible = "allwinner,sun60iw2p1-pinctrl";
			device_type = "pio";
			gpio-controller;
			#size-cells = <0x00>;
			#gpio-cells = <0x06>;
			input-debounce = <0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00>;
			phandle = <0x14>;

			pinctrl@07025000 {

				s_twi0@0 {
					allwinner,pins = "PL0", "PL1";
					allwinner,pname = "s_twi0_scl", "s_twi0_sda";
					allwinner,function = "s_twi0";
					allwinner,muxsel = <0x02>;
					allwinner,drive = <0x01>;
					allwinner,pull = <0x01>;
					phandle = <0x15>;
				};

				s_twi0@1 {
					allwinner,pins = "PL0", "PL1";
					allwinner,function = "gpio_out";
					allwinner,muxsel = <0x01>;
					allwinner,drive = <0x01>;
					allwinner,pull = <0x01>;
					phandle = <0x16>;
				};
			};

			sdc0@0 {
				allwinner,pins = "PF0", "PF1", "PF3", "PF4", "PF5";
				allwinner,function = "sdc0";
				allwinner,muxsel = <0x02>;
				allwinner,drive = <0x00>;
				allwinner,pull = <0x01>;
				phandle = <0x3d>;
			};

			sdc0@1 {
