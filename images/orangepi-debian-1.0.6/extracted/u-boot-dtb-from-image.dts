			clock-div = <0x03>;
			clock-output-names = "pll_periph0_400m";
			phandle = <0x03>;
		};

		pll_periph0_300m {
			#clock-cells = <0x00>;
			compatible = "allwinner,fixed-factor-clock";
			clocks = <0x02>;
			clock-mult = <0x01>;
			clock-div = <0x02>;
			clock-output-names = "pll_periph0_300m";
			phandle = <0x04>;
