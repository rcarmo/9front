/dts-v1/;

/ {
	model = "sun60iw2";
	compatible = "allwinner,a733", "arm,sun60iw2p1";
	#address-cells = <0x02>;
	#size-cells = <0x02>;

	clocks {
		compatible = "allwinner,clk-init";
		device_type = "clocks";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;
		reg = <0x00 0x2002000 0x00 0x2000 0x00 0x7010000 0x00 0x400>;

		pll_periph0 {
			#clock-cells = <0x00>;
			compatible = "allwinner,pll-clock";
			assigned-clock-rates = <0x23c34600>;
			lock-mode = "new";
			clock-output-names = "pll_periph0";
			phandle = <0x07>;
		};

		pll_periph0_2x {
			#clock-cells = <0x00>;
			compatible = "allwinner,pll-clock";
			lock-mode = "new";
			clock-output-names = "pll_periph0_2x";
			phandle = <0x01>;
		};

		pll_periph0_800m {
			#clock-cells = <0x00>;
			compatible = "allwinner,pll-clock";
			lock-mode = "new";
			clock-output-names = "pll_periph0_800m";
		};

		pll_periph0_600m {
			#clock-cells = <0x00>;
			compatible = "allwinner,fixed-factor-clock";
			clocks = <0x01>;
			clock-mult = <0x01>;
			clock-div = <0x02>;
			clock-output-names = "pll_periph0_600m";
			phandle = <0x02>;
		};

		pll_periph0_480m {
			#clock-cells = <0x00>;
