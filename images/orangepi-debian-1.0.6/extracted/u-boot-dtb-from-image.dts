			clock-output-names = "lvds0";
			phandle = <0x7b>;
		};

		lvds1 {
			#clock-cells = <0x00>;
			compatible = "allwinner,periph-clock";
			clock-output-names = "lvds1";
			phandle = <0x7f>;
		};

		mipi_dsi0 {
			#clock-cells = <0x00>;
			compatible = "allwinner,periph-clock";
			assigned-clock-parents = <0x11>;
			assigned-clock-rates = <0x8f0d180>;
			clock-output-names = "mipi_dsi0";
			phandle = <0x70>;
